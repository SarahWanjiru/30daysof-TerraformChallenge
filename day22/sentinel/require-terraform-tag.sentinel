# sentinel/require-terraform-tag.sentinel
# Blocks any plan where a resource is missing the ManagedBy = "terraform" tag.
# Ensures every resource created by Terraform is identifiable in the AWS console.

import "tfplan/v2" as tfplan

main = rule {
  all tfplan.resource_changes as _, rc {
    rc.change.after.tags["ManagedBy"] is "terraform"
  }
}
