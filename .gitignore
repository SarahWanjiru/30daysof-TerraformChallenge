# Terraform providers and plugins
**/.terraform/

# State files (may contain sensitive data)
*.tfstate
*.tfstate.backup

# Lock info (ephemeral)
*.tfstate.lock.info

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# Variable files (may contain secrets)
*.tfvars
*.tfvars.json
!example.tfvars

# Env vars / secrets
*.env
.env
